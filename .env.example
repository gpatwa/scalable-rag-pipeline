# .env.example
# Copy this to .env and fill in the values:  cp .env.example .env

# --- APP SETTINGS ---
ENV=dev
LOG_LEVEL=INFO

# --- DATABASE (Postgres / Aurora) ---
# Option A: Full URL (dev — password embedded)
DATABASE_URL=postgresql+asyncpg://ragadmin:changeme@localhost:5432/rag_db

# Option B: Individual parts (prod — password from Key Vault)
# DB_HOST=ragplatform-pgdb-central.postgres.database.azure.com
# DB_USER=ragadmin
# DB_NAME=ragdb
# DB_PORT=5432
# DB_PASSWORD=  # Injected from Key Vault at startup

# --- CACHE (Redis) ---
# Option A: Full URL (dev)
REDIS_URL=redis://localhost:6379/0

# Option B: Individual parts (prod — password from Key Vault)
# REDIS_HOST=rag-platform-aks-redis.redis.cache.windows.net
# REDIS_PORT=6380
# REDIS_SSL=true
# REDIS_PASSWORD=  # Injected from Key Vault at startup

# --- VECTOR DB (Qdrant) ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=rag_collection

# --- GRAPH DB (Neo4j) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# --- SECURITY ---
JWT_SECRET_KEY=change-this-to-a-secure-random-string   # Generate: openssl rand -hex 32

# --- SECRETS MANAGEMENT ---
# For local dev, use "env" (default — reads from this file)
SECRETS_PROVIDER=env

# For Azure Key Vault (prod):
# SECRETS_PROVIDER=azure_kv
# AZURE_KEY_VAULT_URL=https://rag-platform-aks-kv.vault.azure.net

# For AWS Secrets Manager (prod):
# SECRETS_PROVIDER=aws_sm
# SECRETS_PREFIX=rag-platform/prod/

# --- AWS / MinIO (Object Storage) ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=rag-platform-docs-dev
S3_ENDPOINT_URL=http://localhost:9000          # Remove for real AWS S3

# --- LLM / Embeddings (Ollama for local, Ray Serve for prod) ---
# Local (Ollama):
RAY_LLM_ENDPOINT=http://localhost:11434/v1/chat/completions
RAY_EMBED_ENDPOINT=http://localhost:11434/api/embeddings
LLM_MODEL=llama3

# Production (Ray Serve) — uncomment and replace above:
# RAY_LLM_ENDPOINT=http://llm-service:8000/llm
# RAY_EMBED_ENDPOINT=http://embed-service:8000/embed

# OpenAI (alternative to Ray Serve):
# LLM_PROVIDER=openai
# EMBED_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# --- MULTIMODAL RAG (Gemini Embedding) ---
# Enables cross-modal retrieval (text + images) using Gemini unified embeddings
MULTIMODAL_ENABLED=false
# GOOGLE_API_KEY=your-gemini-api-key       # Required when MULTIMODAL_ENABLED=true
GEMINI_EMBED_MODEL=gemini-embedding-2-preview
GEMINI_EMBED_DIMENSIONS=768
MAX_IMAGE_SIZE_MB=10

# --- CONTEXT LAYERS (Enterprise Knowledge Enrichment) ---
# Enriches RAG responses with glossary, metadata, code context, and business rules
CONTEXT_LAYERS_ENABLED=false
CONTEXT_LAYER1_ENABLED=true                # Document metadata & usage
CONTEXT_LAYER2_ENABLED=true                # Annotations & glossary
CONTEXT_LAYER3_ENABLED=true                # Code & pipeline context
CONTEXT_LAYER4_ENABLED=true                # Business context
CONTEXT_LAYERS_MAX_TOKENS=1500
CONTEXT_FRESHNESS_DECAY_DAYS=90

# --- DATA ANALYTICS AGENT (Text-to-SQL) ---
# Answers business questions from structured data with tables + charts
DATA_ANALYTICS_ENABLED=false
# ANALYTICS_DB_URL=                        # Separate read-only DB (optional, falls back to DATABASE_URL)
ANALYTICS_QUERY_TIMEOUT=10                 # Max seconds per SQL query
ANALYTICS_MAX_ROWS=1000                    # Max rows returned per query

# --- WEB SEARCH TOOL ---
# TAVILY_API_KEY=tvly-...                  # For web search fallback

# --- OBSERVABILITY (Optional) ---
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
