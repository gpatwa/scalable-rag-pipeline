# .env.example
# Copy this to .env and fill in the values:  cp .env.example .env

# --- APP SETTINGS ---
ENV=dev
LOG_LEVEL=INFO
JWT_SECRET_KEY=change-this-to-a-secure-random-string

# --- DATABASE (Postgres / Aurora) ---
DATABASE_URL=postgresql+asyncpg://ragadmin:changeme@localhost:5432/rag_db

# --- CACHE (Redis) ---
REDIS_URL=redis://localhost:6379/0

# --- VECTOR DB (Qdrant) ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=rag_collection

# --- GRAPH DB (Neo4j) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# --- AWS / MinIO (Object Storage) ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=rag-platform-docs-dev
S3_ENDPOINT_URL=http://localhost:9000          # Remove for real AWS S3

# --- LLM / Embeddings (Ollama for local, Ray Serve for prod) ---
# Local (Ollama):
RAY_LLM_ENDPOINT=http://localhost:11434/v1/chat/completions
RAY_EMBED_ENDPOINT=http://localhost:11434/api/embeddings
LLM_MODEL=llama3

# Production (Ray Serve) — uncomment and replace above:
# RAY_LLM_ENDPOINT=http://llm-service:8000/llm
# RAY_EMBED_ENDPOINT=http://embed-service:8000/embed

# --- OBSERVABILITY (Optional) ---
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
